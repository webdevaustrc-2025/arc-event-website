generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  passwordHash  String?
  role          String         @default("user")
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  emailVerified DateTime?
  accounts      Account[]
  certificates  Certificate[]
  leaderboard   Leaderboard[]
  registrations Registration[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Segment {
  id            Int            @id @default(autoincrement())
  name          String
  description   String
  rules         String
  prizePool     String
  status        String         @default("active")
  imageUrl      String?
  certificates  Certificate[]
  registrations Registration[]
  schedule      Schedule[]
}

model Registration {
  id            Int      @id @default(autoincrement())
  userId        Int
  segmentId     Int
  teamName      String
  status        String   @default("pending")
  paymentStatus String   @default("unpaid")
  qrToken       String   @unique
  createdAt     DateTime @default(now())
  segment       Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Schedule {
  id           Int      @id @default(autoincrement())
  segmentId    Int?
  title        String
  startTime    DateTime
  endTime      DateTime
  venue        String
  displayOrder Int      @default(0)
  segment      Segment? @relation(fields: [segmentId], references: [id])
}

model Sponsor {
  id           Int     @id @default(autoincrement())
  name         String
  logoUrl      String
  tier         String
  websiteUrl   String?
  displayOrder Int     @default(0)
}

model FAQ {
  id           Int    @id @default(autoincrement())
  question     String
  answer       String
  displayOrder Int    @default(0)
}

model PastEvent {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  description String
  imageUrl    String?
}

model Certificate {
  id        Int      @id @default(autoincrement())
  userId    Int
  segmentId Int
  fileUrl   String
  issuedAt  DateTime @default(now())
  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leaderboard {
  id     Int  @id @default(autoincrement())
  userId Int
  points Int
  rank   Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
